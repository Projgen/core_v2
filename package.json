{
  "name": "@projgen/cli",
  "version": "2.0.1",
  "description": "A project scaffolding cli tool",
  "license": "MIT",
  "author": "LorisRue",
  "keywords": [
    "cli"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Projgen/core_v2.git"
  },
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec \"ts-node ./src/index.ts\"",
    "build": "tsc --outDir dist",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/yargs": "^17.0.35",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "inquirer": "^13.4.2",
    "yargs": "^18.0.0",
    "zod": "^4.3.6"
  },
  "bin": {
    "projgen": "./dist/index.js"
  }
}
