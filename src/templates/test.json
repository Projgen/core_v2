{
  "id": "example-template",
  "name": "Example Template",
  "description": "A minimal template for testing purposes",
  "version": "1.0.0",
  "author": "John Doe",
  "variables": [
    {
      "name": "test",
      "type": "string",
      "description": "A test variable",
      "message": "Write 'test'",
      "required": true
    }
  ],
  "steps": [
    {
      "type": "run",
      "when": [
        { "variable": "test", "operator": "matches", "value": "^t.*t$" }
      ],
      "command": "npm",
      "args": ["install", "react-scripts"]
    }
  ]
}
