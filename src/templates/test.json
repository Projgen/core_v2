{
  "id": "example-template",
  "name": "Example Template",
  "description": "A minimal template for testing purposes",
  "version": "1.0.0",
  "author": "John Doe",
  "variables": [
    {
      "name": "message",
      "type": "string",
      "message": "What is your message?",
      "description": "The message to display",
      "default": "Hello, World!",
      "required": true
    }
  ],
  "steps": [
    {
      "type": "run",
      "command": "echo {{message}}"
    },
    {
      "type": "write",
      "path": "something/output.txt",
      "url": "https://raw.githubusercontent.com/Projgen/core_v2/refs/heads/master/src/index.ts?token=GHSAT0AAAAAADXANFIAOT5L5GECPSYSYU7E2PPCCVQ"
    }
  ]
}
