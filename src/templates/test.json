{
  "id": "example-template",
  "name": "Example Template",
  "description": "A minimal template for testing purposes",
  "version": "1.0.0",
  "author": "John Doe",
  "variables": [
    {
      "name": "message",
      "type": "string",
      "message": "What is your message?",
      "description": "The message to display",
      "default": "Hello, World!",
      "required": true
    }
  ],
  "steps": [
    {
      "type": "run",
      "command": "echo {{message}}"
    }
  ]
}
