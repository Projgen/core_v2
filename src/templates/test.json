{
  "id": "example-template",
  "name": "Example Template",
  "description": "A minimal template for testing purposes",
  "version": "1.0.0",
  "author": "John Doe",
  "variables": [],
  "steps": [
    {
      "type": "run",
      "command": "ping google.com"
    },
    {
      "type": "write",
      "path": "temp.txt",
      "content": "Hello, World!"
    },
    {
      "type": "run",
      "command": "type temp.txt"
    },
    {
      "type": "patch-text",
      "path": "temp.txt",
      "find": "Hello",
      "operation": "replace",
      "content": "Goodbye"
    },
    {
      "type": "run",
      "command": "type temp.txt"
    }
  ]
}
