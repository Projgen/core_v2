{
  "id": "example-template",
  "name": "Example Template",
  "description": "A minimal template for testing purposes",
  "version": "1.0.0",
  "author": "John Doe",
  "variables": [],
  "steps": [
    {
      "type": "write",
      "path": "example.json",
      "content": "{\"someKey\": \"someValue\", \"someObject\": {\"nestedArray\": [\"nestedValue1\", {\"deeplyNestedKey\": \"deeplyNestedValue\"}]}}"
    },
    {
      "type": "patch-json",
      "path": "example.json",
      "operation": "remove",
      "jsonPath": ["someObject"]
    },
    {
      "type": "run",
      "command": "type example.json"
    }
  ]
}
